# Discord Bot Configuration
# =========================

# Your Discord bot token from the Discord Developer Portal
# Get it from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# The Discord server (guild) ID where the bot will operate
# Enable Developer Mode in Discord, right-click your server, and copy ID
DISCORD_GUILD_ID=123456789012345678

# Discord Application ID (required for Deno Deploy)
# Found in Discord Developer Portal > General Information > Application ID
DISCORD_APPLICATION_ID=123456789012345678

# Discord Public Key (required for Deno Deploy HTTP Interactions)
# Found in Discord Developer Portal > General Information > Public Key
DISCORD_PUBLIC_KEY=your_public_key_here

# OpenRouter API Configuration
# ============================

# Your OpenRouter API key for AI-powered expense parsing
# Get it from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_api_key_here

# Security Configuration
# ======================

# Comma-separated list of Discord user IDs allowed to use this bot
# Enable Developer Mode in Discord, right-click a user, and copy ID
# Example: 123456789012345678,987654321098765432
FAMILY_USER_IDS=123456789012345678,987654321098765432

# Deno Deploy Configuration (auto-set by Deno Deploy)
# ===================================================
# DENO_DEPLOYMENT_ID - Set automatically by Deno Deploy
# PORT - HTTP server port (default: 8000)
